# lfl-proxy configuration - copy to .env.local (gitignored) and fill in.
#
#   cp .env.example .env.local
#   # edit .env.local with your real values
#   set -a; . ./.env.local; set +a
#   python3 lfl-proxy.py
#
# .env.local is gitignored and must NEVER be committed - it is where the real
# upstream host and key live. The leak gate (tests/check_no_leaks.sh) will fail
# the build if a real host or key ends up in a tracked file.

# Base URL of the upstream OpenAI-compatible model endpoint.
# Examples:
#   a bigger model on another local port:  http://127.0.0.1:1236
#   a host on your own private network:    http://model-host.example:PORT
LFL_PROXY_UPSTREAM=http://127.0.0.1:PORT

# Bearer token, if the upstream requires one. Leave blank for a keyless local
# model. This value is held only here, injected server-side, and never sent to
# the browser extension.
LFL_PROXY_API_KEY=

# Loopback port the proxy listens on. 1238 is lfl-terminal's default, so
# running the proxy there is a drop-in swap - but stop any model already bound
# to that port first, or choose another and point the extension at it.
LFL_PROXY_PORT=1238
